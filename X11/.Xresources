URxvt.geometry: 82x26
! may be customized through menu: Ctrl + middle button
!URxvt.urgentOnBell:  true
URxvt.silent: true
URxvt.scrollBar: yes
URxvt.scrollBar_right: yes
URxvt.scrollBar_floating: yes
URxvt.scrollColor: #2a2a2a
!URxvt.background: #000000
URxvt.background: #000000
URxvt.color0: #000000
!URxvt.background: rgb:10/10/10
URxvt.foreground: #babdb6
URxvt.font: terminus-18
!URxvt.font: -xos4-terminus-medium-r-normal--14-140-72-72-c-80-iso10646-1
URxvt.saveLines: 8192
URxvt.perl-ext-common: default,tabbed,confirm-paste,keyboard-select
!URxvt.keysym.M-a: perl:keyboard-select:activate
URxvt.keysym.Super_L: perl:keyboard-select:activate
URxvt.tabbed.tab-bg: 8
URxvt.cutchars: "‘\"’“”&()*,;<=>?[]^{|}:$#"
URxvt.pasteOneLine: yes
URxvt.color1: rgb:CC/00/00
URxvt.color2: rgb:4E/9A/06
URxvt.color3: rgb:C4/A0/00
URxvt.color4: rgb:34/65/A4
URxvt.color5: rgb:75/50/7B
URxvt.color6: rgb:06/98/9A
URxvt.color7: rgb:D3/D7/CF
URxvt.color8: rgb:55/57/53
URxvt.color9: rgb:EF/29/29
URxvt.color10: rgb:8A/E2/34
URxvt.color11: rgb:FC/E9/4F
URxvt.color12: rgb:72/9F/CF
URxvt.color13: rgb:AD/7F/A8
URxvt.color14: rgb:34/E2/E2
URxvt.color15: rgb:EE/EE/EC
URxvt.print-pipe: "cat > /dev/null"
Xft.dpi: 96
