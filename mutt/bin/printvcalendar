#!/usr/bin/env python3

import sys
import datetime
import re
import textwrap

KEY_VALUE_RE = re.compile("(?P<key>[-\w]+)[:;](?P<value>.*)")
KEY_ORDER = {
    "SUMMARY":      0,
    "ORGANIZER":    5,
    "ATTENDEE":    10,
    "DTSTART":     15,
    "DTEND":       20,
    "LOCATION":    25,
    "DESCRIPTION": 30,
}
CEST_NAMES = [
    "Central European Standard Time",
    "Central Europe Standard Time",
    "W. Europe Standard Time",
    "Europe/Warsaw",
]

is_helper = sys.argv[1:] == ["-w"]

sections = []

def collect_field(fields, sections, key, value):
    def should_collect():
        if sections == ["VCALENDAR"] and key in ["METHOD"]:
            return True
        if sections == ["VCALENDAR", "VEVENT"] and key in KEY_ORDER:
            return True
        return False
    if should_collect():
        fields.append((key, value))

timezone = None
processed_key = None
fields = []

for line in map(str.rstrip, sys.stdin):
    if not line:
        continue

    if line[:1].isspace():
        processed_value += line.lstrip()
        continue

    key, value = KEY_VALUE_RE.match(line).groups()
    if key == "BEGIN":
        sections.append(value)
    elif key == "END":
        section = sections.pop()
        if value != section:
            exit("BEGIN/END mismatch")
    elif sections == ["VCALENDAR", "VTIMEZONE"] and key == "TZID":
        timezone = value
    else:
        if processed_key is not None:
            collect_field(fields, sections, processed_key, processed_value)
        processed_key = key
        processed_value = value

def field_order(field):
    key, value = field
    if key == "METHOD":
        return -10
    return KEY_ORDER.get(key, 50)

def clear_screen():
    print("\033[2J\033[H", end="", flush=True)

def wait():
    with open("/dev/tty") as f:
        f.read(1)

if is_helper:
    clear_screen()

fields.sort(key=field_order)
prev_key = fields[0][0] if fields else None
for key, value in fields:
    if key != prev_key:
        print()
    if key in ["DTSTART", "DTEND"]:
        _, _, dt = value.rpartition(":")
        if timezone == "UTC" or dt.endswith("Z"):
            dt = datetime.datetime.strptime(dt[:-1], "%Y%m%dT%H%M%S")
            dt = dt.replace(tzinfo=datetime.timezone.utc).astimezone()
        elif timezone in CEST_NAMES:
            dt = datetime.datetime.strptime(dt, "%Y%m%dT%H%M%S")
        else:
            exit("Unknown timezone")
        diff = (dt.date() - datetime.date.today()).days
        dt = dt.strftime("%a %Y-%m-%d %H:%M")
        print(f"{key:12} {value}")
        print(f"{key:12} {dt} ({diff} days)")
    elif key == "DESCRIPTION":
        value = value.replace(r"\,", ",").replace(r"\n", "\n").rstrip()
        print(f"{key}:")
        for paragraph in [ textwrap.fill(paragraph, break_long_words=False) for paragraph in value.split("\n") ]:
            print(paragraph)
    else:
        print(f"{key:12} {value}")
    prev_key = key

if is_helper:
    print()
    print("press enter to continue...")
    wait()
